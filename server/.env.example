# Server Port & Environment
PORT=5000
NODE_ENV=production

# Database Connection (MongoDB Atlas or Local Instance)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai-crop-system?retryWrites=true&w=majority

# Authentication Secret Key
JWT_SECRET=your_production_jwt_secret_key_here_min_32_chars

# Client URL (For CORS whitelist)
CLIENT_URL=https://your-app-name.vercel.app

# AI Model Directories (Optional overrides)
MODEL_STORAGE_PATH=models/model_versions
